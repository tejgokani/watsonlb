# Copy to .env and fill in real values
# Production: set these via Render dashboard → Environment

# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://...                    # Neon connection string (pooler URL)
JWT_SECRET=<64-char random string>               # node -e "require('crypto').randomBytes(48).toString('base64url')" | pbcopy

# ── URLs — update once Render + Vercel give you hostnames ────────────────────
PROXY_BASE_URL=https://watsonlb-proxy.onrender.com
DASHBOARD_URL=https://watsonlb.vercel.app

# ── Optional — leave blank to skip email/payments until ready ─────────────────
ADMIN_EMAIL=you@yourdomain.com                   # First login with this email gets admin
RESEND_API_KEY=re_...                            # resend.com API key for email alerts

# ── Razorpay — add after approval ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ── OAuth — add after app registration ────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...

# ── Defaults (don't change) ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
