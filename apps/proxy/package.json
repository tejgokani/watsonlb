{
  "name": "@watsonlb/proxy",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx --tsconfig tsconfig.dev.json --env-file .env --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@neondatabase/serverless": "^0.10.4",
    "@watsonlb/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.44.1",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "nanoid": "^5.1.5",
    "node-cron": "^4.1.0",
    "pino-pretty": "^13.0.0",
    "razorpay": "^2.9.6",
    "resend": "^4.5.2",
    "undici": "^7.10.0",
    "ws": "^8.18.2",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.14",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
